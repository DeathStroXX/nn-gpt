    "prompt": [
      "Task: Improve the baseline CIFAR-10 model using one constrained structured edit.",
      "",
      "=== BASELINE MODEL ===",
      "<hp>{prm}</hp>",
      "",
      "<tr>",
      "{transform_code}",
      "</tr>",
      "",
      "<nn>",
      "{nn_code}",
      "</nn>",
      "",
      "Current performance: {accuracy}",
      "Goal: Maximize first-epoch '{metric}' on 'cifar-10' for 'img-classification'",
